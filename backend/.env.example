# 后端运行时配置（pydantic-settings 自动加载 backend/.env）。
# 复制为 .env 后按需修改；.env 已在 .gitignore 中不入库。
# SSOT：backend/app/core/config.py

# CORS 白名单（JSON 数组；生产环境替换为真实前端域名）
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# 数据库路径（相对 backend/ 目录或绝对路径）
DB_PATH=../investment_data/portfolio.db

# 日志级别：DEBUG / INFO / WARNING / ERROR
# 生产建议 WARNING（见 CLAUDE.md 工程规范）
LOG_LEVEL=INFO

# ========================================
# SMTP 邮件发送（P5 发送投资报告，V2）
# ========================================
# 163 邮箱示例（授权码在邮箱"设置→POP3/SMTP/IMAP→开启"中生成，不是登录密码）
# QQ 邮箱示例：SMTP_HOST=smtp.qq.com / SMTP_PORT=465
# Gmail 示例：SMTP_HOST=smtp.gmail.com / SMTP_PORT=587（STARTTLS）
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=

# ========================================
# 定时任务（APScheduler，每月自动发送报告）
# ========================================
# cron 表达式（分 时 日 月 周）；默认每月 1 号 9:00 发送（北京时区）
REPORT_SCHEDULE_CRON=0 9 1 * *
# 是否启用定时任务（生产服务器 true；本地开发建议 false 避免意外发送）
REPORT_SCHEDULE_ENABLED=false
